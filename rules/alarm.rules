//import org.joda.time
import org.openhab.core.library.types.*
import org.openhab.core.persistence.*
import org.openhab.model.script.actions.*

rule "Set all necessary variables for alarm"

when
	System started
then
	sendCommand(LogAlarm, OFF)
	logInfo("alarm", "Nastavljene začetne vrednosti - " + LogAlarm.state)
end


rule "Change in motion detection"

when
	Item Mot changed to ON 
then
	logInfo("alarm", "Zaznano je bilo gibanje - " + LogAlarm.state)
	sendCommand(LogAlarm, OFF)
	logInfo("alarm", "Nastavljene začetne vrednosti - " + LogAlarm.state)
end


